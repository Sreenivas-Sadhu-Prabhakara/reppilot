# RepPilot runs fully offline with deterministic mocks — no keys required.

# Server port (default 8102)
PORT=8102

# ------------------------------------------------------------------
# Live-mode upgrades. Documented only; the mock is the sole
# implementation shipped in this MVP. Setting these today has no effect.
# ------------------------------------------------------------------

# Google Business Profile: switches the profile/review provider
# from the deterministic mock to the live Google API.
# GOOGLE_PLACES_API_KEY=

# Reply drafting: switches the ReplyDrafter from the built-in
# template engine to Claude-powered drafting.
# ANTHROPIC_API_KEY=

# WhatsApp delivery: switches the sender from the mock outbox
# to live WhatsApp sends via AiSensy.
# AISENSY_API_KEY=
